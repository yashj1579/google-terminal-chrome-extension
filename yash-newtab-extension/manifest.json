{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.3.0",
  "description": "Custom terminal new-tab page",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "assets/custom_google_favicon.png",
    "48": "assets/custom_google_favicon.png",
    "128": "assets/custom_google_favicon.png"
  },
  "permissions": [
    "geolocation",
    "tabs"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.ipify.org/*",
    "https://*.tile.openstreetmap.org/*"
  ]
}
